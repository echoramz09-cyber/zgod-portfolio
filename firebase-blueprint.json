{
  "entities": {
    "playerConfig": {
      "title": "Player Configuration",
      "description": "Configuration for the player's profile, including image and scale.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "imageScale": { "type": "number" },
        "textOffset": { "type": "number" },
        "leftLogoUrl": { "type": "string" },
        "leftLogoScale": { "type": "number" },
        "rightLogoUrl": { "type": "string" },
        "rightLogoScale": { "type": "number" },
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "handlePrefix": { "type": "string" },
        "role": { "type": "string" },
        "team": { "type": "string" },
        "teamLogo": { "type": "string" },
        "bio": { "type": "string" },
        "twitterUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "twitchUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "youtubeChannelId": { "type": "string" },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "stats": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["imageUrl", "imageScale", "handle"]
    }
  },
  "firestore": {
    "/config/player": {
      "schema": "playerConfig",
      "description": "The single document containing player profile configuration."
    }
  }
}
