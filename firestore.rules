rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: player
    // Fields:
    //   - imageUrl: string (required) - The URL of the player's image.
    //   - imageScale: number (required) - The scale of the image (0.1 to 2.0).
    //   - updatedAt: timestamp (optional) - Last update time.
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated();
    }

    function isValidPlayerConfig(data) {
      return data.keys().hasAll(['imageUrl', 'imageScale', 'textOffset', 'leftLogoUrl', 'leftLogoScale', 'rightLogoUrl', 'rightLogoScale']) &&
             data.imageUrl is string &&
             data.imageScale is number &&
             data.imageScale >= 0.1 &&
             data.imageScale <= 5.0 &&
             data.textOffset is number &&
             data.textOffset >= -500 &&
             data.textOffset <= 500 &&
             data.leftLogoUrl is string &&
             data.leftLogoScale is number &&
             data.leftLogoScale >= 0.1 &&
             data.leftLogoScale <= 3.0 &&
             data.rightLogoUrl is string &&
             data.rightLogoScale is number &&
             data.rightLogoScale >= 0.1 &&
             data.rightLogoScale <= 3.0;
    }

    match /config/player {
      // Anyone can read the config
      allow read: if true;
      
      // Allow the admin (authenticated via our panel) to write
      allow write: if isAdmin() && isValidPlayerConfig(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
